# Mangalore Traffic AI — Example Environment File
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your local values.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── SUMO ─────────────────────────────────────────────────────────────────────
# Path to your SUMO installation.
# Windows (Eclipse installer): D:/SUMO
# Linux (apt install sumo):    /usr/share/sumo
SUMO_HOME=D:/SUMO

# ── Simulation ────────────────────────────────────────────────────────────────
SUMO_CONFIG_PATH=simulation/config.sumocfg
MAX_SIMULATION_STEPS=3600

# ── Training ──────────────────────────────────────────────────────────────────
RL_ALGORITHM=PPO
PPO_TOTAL_TIMESTEPS=200000
PPO_MODEL_PATH=models/ppo_mangalore_sumo
LSTM_MODEL_PATH=models/lstm_traffic.pt
RF_MODEL_PATH=models/random_forest.pkl

# ── Map ───────────────────────────────────────────────────────────────────────
MANGALORE_LAT=12.8700
MANGALORE_LON=74.8436
MANGALORE_OSM_RADIUS=2000

# ── Dashboard ─────────────────────────────────────────────────────────────────
STREAMLIT_PORT=8501
DEBUG=False
