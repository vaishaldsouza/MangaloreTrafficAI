# =============================================================================
# Mangalore Traffic AI — .env.example
# -----------------------------------------------------------------------------
# Copy this file to .env and fill in your local values.
#   cp .env.example .env   (Linux/macOS)
#   copy .env.example .env (Windows)
# =============================================================================

# ── SUMO ─────────────────────────────────────────────────────────────────────
SUMO_HOME=D:/SUMO
SUMO_CONFIG_PATH=simulation/config.sumocfg
SUMO_GUI=false

# ── Simulation ────────────────────────────────────────────────────────────────
MAX_SIMULATION_STEPS=3600
SIMULATION_STEP_LENGTH=1
SIMULATION_AGENT_STEPS=5
MAP_UPDATE_FREQ=20

# ── Reinforcement Learning ────────────────────────────────────────────────────
RL_ALGORITHM=PPO
REWARD_TYPE=wait_time
PPO_MODEL_PATH=models/ppo_mangalore_sumo
PPO_TOTAL_TIMESTEPS=200000
PPO_LEARNING_RATE=0.0003
PPO_N_STEPS=2048
PPO_BATCH_SIZE=64
DQN_MODEL_PATH=models/dqn_mangalore_sumo
DQN_TOTAL_TIMESTEPS=200000
DQN_LEARNING_RATE=0.0001

# ── Classical ML ─────────────────────────────────────────────────────────────
RF_MODEL_PATH=models/random_forest.pkl
RF_ENCODER_PATH=models/rf_label_encoder.pkl
RF_N_ESTIMATORS=200
RF_MAX_DEPTH=10
LSTM_MODEL_PATH=models/lstm_traffic.pt
LSTM_SEQ_LEN=12
LSTM_HIDDEN_SIZE=128
LSTM_EPOCHS=50
LSTM_LEARNING_RATE=0.001

# ── Optimisation & XAI ───────────────────────────────────────────────────────
OPTUNA_N_TRIALS=50
OPTUNA_STUDY_NAME=mangalore_traffic_optuna
SHAP_SAMPLE_SIZE=200

# ── Map ───────────────────────────────────────────────────────────────────────
MANGALORE_LAT=12.8700
MANGALORE_LON=74.8436
MANGALORE_OSM_RADIUS=2000

# ── Database & Exports ───────────────────────────────────────────────────────
DB_PATH=simulation_history.db
EXPORT_REPORT_DIR=reports/

# ── Dashboard (Legacy Streamlit) ──────────────────────────────────────────────
STREAMLIT_PORT=8501
DEBUG=False

# ── API & Security (FastAPI) ──────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
JWT_SECRET=your_super_secret_jwt_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Frontend (Next.js Dashboard V2) ───────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_MAPBOX_TOKEN=      # Optional: for advanced map layers
