# =============================================================================
# Mangalore Traffic AI — .gitignore
# =============================================================================


# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.spec


# ── Testing / Coverage ────────────────────────────────────────────────────────
.pytest_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover


# ── Virtual Environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/


# ── Trained Model Binaries ────────────────────────────────────────────────────
# These are large files that should be regenerated from training scripts.
models/*.zip          # Stable Baselines3 PPO / DQN checkpoints
models/*.pkl          # Scikit-learn Random Forest + Label Encoder
models/*.pt           # PyTorch LSTM / GCN-LSTM weights
models/*.h5           # Keras / TF model weights (if added later)
models/*.onnx         # ONNX exported models


# ── Optimisation Studies (Optuna) ─────────────────────────────────────────────
optuna_study.db
optuna_study.db-journal


# ── SUMO Simulation Artefacts ─────────────────────────────────────────────────
# Regenerate these by running: python simulation/generate_network.py
simulation/output/         # SUMO runtime output (summary.xml, tripinfo.xml, etc.)
simulation/*.osm           # Raw OpenStreetMap XML download  (~1.5 MB)
simulation/*.net.xml       # SUMO road network file          (~11 MB)
simulation/*.rou.xml       # Generated vehicle route files
simulation/trips.xml       # Random-trip source file
simulation/uploaded_network.osm   # User-uploaded custom map (Data Hub)
simulation/uploaded_trips.xml     # User-uploaded custom trips


# ── Logs / TensorBoard ────────────────────────────────────────────────────────
logs/
runs/
tensorboard/
*.log
training_log_*.txt


# ── Database & Exports ────────────────────────────────────────────────────────
simulation_history.db      # SQLite history database (regenerated at runtime)
simulation_history.db-shm
simulation_history.db-wal
reports/                   # Auto-generated HTML/PDF reports
mangalore_traffic_*.html   # Exported dashboard reports
mangalore_traffic_*.pdf


# ── Data Hub Uploads ──────────────────────────────────────────────────────────
uploads/                   # Any user-uploaded files
*.uploaded.csv
*.uploaded.osm
*.uploaded.xml


# ── osmnx / networkx Cache ───────────────────────────────────────────────────
cache/
*.graphml


# ── Environment Variables ─────────────────────────────────────────────────────
# Keep .env.example in the repo. NEVER commit .env (it contains secrets).
.env
!.env.example


# ── Streamlit Runtime ─────────────────────────────────────────────────────────
.streamlit/


# ── OS Junk ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*.tmp
*~


# ── IDE / Editor ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.iml
*.suo
*.user
.history/


# ── Jupyter Notebooks ─────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb


# ── Frontend & Node.js (Dashboard V2) ────────────────────────────────────────
node_modules/
.next/
out/
build/
.vercel
*.tsbuildinfo
package-lock.json

# Local env files
.env.local
.env.development.local
.env.test.local
.env.production.local
