# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*$py.class
*.egg-info/
dist/
build/
.eggs/

# ── Testing / Coverage ────────────────────────────────────────────────────────
.pytest_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Trained model files (large binaries — regenerate with train scripts) ──────
models/*.zip        # SB3 PPO / DQN checkpoints
models/*.pkl        # scikit-learn Random Forest
models/*.pt         # PyTorch LSTM / GCN weights

# ── SUMO simulation artefacts (regenerate with generate_network.py) ───────────
simulation/output/       # SUMO runtime output (summary.xml, tripinfo.xml)
simulation/*.osm         # raw OpenStreetMap XML  (~1.5 MB)
simulation/*.net.xml     # SUMO road network      (~11 MB)
simulation/*.rou.xml     # generated routes
simulation/trips.xml     # random-trip source file

# ── Logs / TensorBoard ────────────────────────────────────────────────────────
logs/
runs/
*.log

# ── Environment variables (keep .env.example in repo, not .env) ───────────────
.env

# ── OS / editor junk ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.iml

# ── Streamlit runtime ─────────────────────────────────────────────────────────
.streamlit/

# ── osmnx / networkx graph cache ─────────────────────────────────────────────
cache/

# ── Jupyter notebooks (optional, keep if you add them) ───────────────────────
# .ipynb_checkpoints/
